# Public key — card tokenization and 3DS session creation (client-side safe)
NEXT_PUBLIC_PUBLICSQUARE_KEY=pk_test_your_publishable_key

# Secret key — payment intent create/confirm/complete (server-side only, NEVER exposed to client)
PSQ_SECRET_KEY=sk_test_your_secret_key

# API BASE URL
# PRODUCTION: Https://api.publicsquare.com
# TEST:  https://staging.api.publicsquare.com
PSQ_PAYMENTS_API_BASE_URL=https://staging.api.publicsquare.com

# ENVIRONMENT: production / staging
# This needs to match the ENVIRONMENT component, when it exists
# production: ENVIRONMENT ="PRODUCTION"
# staging: ENVIRONMENT ="TEST"
NEXT_PUBLIC_ENVIRONMENT=staging